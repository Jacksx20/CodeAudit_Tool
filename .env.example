# CodeAudit Web配置文件

# 大模型API配置
# 支持OpenAI API或兼容的API服务

# API密钥(必填)
LLM_API_KEY=your-api-key-here

# 模型名称(可选,默认: gpt-4)
LLM_MODEL=gpt-4

# API基础URL(可选,默认: https://api.openai.com/v1)
# 如果使用其他兼容服务,请修改此地址
# 例如:
# - OpenAI: https://api.openai.com/v1
# - Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
# - 其他兼容服务: https://your-api-endpoint/v1
LLM_BASE_URL=https://api.openai.com/v1

# Web服务配置
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=False

# 文件上传配置
MAX_CONTENT_LENGTH=104857600  # 100MB

# 审计配置
ENABLE_LLM=true
ENABLE_FORWARD_AUDIT=true
ENABLE_REVERSE_AUDIT=true
ENABLE_ATTACK_CHAIN=true
