        "severity": "critical",
        "sinks": [
            {
                "function": "loads",
                "module": "pickle",
                "pattern": "pickle\\.loads\\s*\\(.*request\\..*\\)",
                "description": "pickle.loads with user input",
                "remediation": "使用JSON或其他安全格式"
            },
            {
                "function": "load",
                "module": "pickle",
                "pattern": "pickle\\.load\\s*\\(.*request\\..*\\)",
                "description": "pickle.load with user input",
                "remediation": "使用JSON或其他安全格式"
            },
            {
                "function": "yaml.load",
                "module": "yaml",
                "pattern": "yaml\\.load\\s*\\(.*Loader\\s*=\\s*yaml\\.Loader.*\\)",
                "description": "yaml.load with unsafe Loader",
                "remediation": "使用yaml.safe_load"
            },
            {
                "function": "yaml.unsafe_load",
                "module": "yaml",
                "pattern": "yaml\\.unsafe_load\\s*\\(.*\\)",
                "description": "yaml.unsafe_load",
                "remediation": "使用yaml.safe_load"
            },
            {
                "function": "marshal.loads",
                "module": "marshal",
                "pattern": "marshal\\.loads\\s*\\(.*\\)",
                "description": "marshal.loads with user input",
                "remediation": "避免使用marshal处理不可信数据"
            },
            {
                "function": "unserialize",
                "module": "php",
                "pattern": "unserialize\\s*\\(.*\\$_.*\\)",
                "description": "PHP unserialize with user input",
                "remediation": "使用JSON或其他安全格式"
            }
        ]
    },
