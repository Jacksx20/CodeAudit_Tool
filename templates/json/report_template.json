{
    "meta": {
        "tool": "{{tool_name}}",
        "version": "{{version}}",
        "generated_at": "{{generated_at}}",
        "target_path": "{{target_path}}",
        "scan_time": {{scan_time}},
        "framework": "{{framework}}"
    },
    "summary": {
